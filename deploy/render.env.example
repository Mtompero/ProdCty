# Render backend environment variables
# Copy these into Render > Environment > Add from .env.
# Replace every CHANGE_ME value inside Render, not in the repository.

NODE_ENV=production
PORT=3000

# MongoDB Atlas connection string.
# Use the /prodcty database name before the question mark.
MONGO_URI=mongodb+srv://prodcty_user:CHANGE_ME_ATLAS_PASSWORD@prodcty.xejtiuo.mongodb.net/prodcty?retryWrites=true&w=majority&appName=ProdCty

# Use a long random value in production.
JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET

# Initial admin account.
ADMIN_EMAIL=admin@admin.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD

# Frontend origin. Add the final Vercel URL here after frontend deploy.
# Example: https://prodcty.vercel.app
CORS_ORIGIN=

# Cloudinary media storage.
MEDIA_STORAGE_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=dje6f62no
CLOUDINARY_API_KEY=CHANGE_ME_CLOUDINARY_API_KEY
CLOUDINARY_API_SECRET=CHANGE_ME_CLOUDINARY_API_SECRET
CLOUDINARY_AUDIO_FOLDER=prodcty/audio
CLOUDINARY_AVATAR_FOLDER=prodcty/avatars

# Optional AI sample risk screening.
# Use auto to run OpenAI when OPENAI_API_KEY exists, otherwise fallback metadata rules.
AI_SAMPLE_SCREENING_ENABLED=auto
OPENAI_API_KEY=CHANGE_ME_OPENAI_API_KEY
OPENAI_SAMPLE_RISK_MODEL=gpt-4.1-mini
