# Backend
PORT=3000
MONGO_URI=mongodb://localhost:27017/prodcty
JWT_SECRET=replace-this-with-a-local-development-secret
UPLOAD_DIR=backend/uploads
ADMIN_EMAIL=admin@admin.com
ADMIN_PASSWORD=Admin12345
CORS_ORIGIN=http://127.0.0.1:4173,http://localhost:4173

# Optional production media storage.
# Leave MEDIA_STORAGE_PROVIDER empty/local for local uploads.
MEDIA_STORAGE_PROVIDER=local
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_AUDIO_FOLDER=prodcty/audio
CLOUDINARY_AVATAR_FOLDER=prodcty/avatars

# Frontend deploy variable for Vercel:
# VITE_API_URL=https://your-render-backend.onrender.com
